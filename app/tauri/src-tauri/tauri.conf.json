{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CIPHERNET",
  "version": "1.0.0",
  "identifier": "net.ciphernet.chat",
  "build": {
    "frontendDist": "../web"
  },
  "app": {
    "windows": [
      {
        "title": "CIPHER//NET",
        "width": 1100,
        "height": 780,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  }
}
